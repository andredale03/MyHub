# ─────────────────────────────────────────────────────────────
# MyHub — variabili d'ambiente
# Copia questo file in `.env` e compila i valori.
# NON committare mai il file `.env` (è in .gitignore).
# ─────────────────────────────────────────────────────────────

# ── Frontend (esposte al browser, prefisso VITE_) ────────────
# Sono sicure da esporre: la chiave anon è protetta dalle RLS.
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# ── Server / Vercel Serverless Functions (mai esposte) ───────
# Service role: bypassa le RLS, usata solo dalle funzioni in api/.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
# Opzionale: se assente, le funzioni usano VITE_SUPABASE_URL.
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# ── Stripe (mai esposte al browser) ──────────────────────────
# Chiave segreta dell'account Stripe (sk_test_... o sk_live_...).
STRIPE_SECRET_KEY=sk_test_...
# ID del Price ricorrente (abbonamento) creato nel catalogo Stripe.
STRIPE_PRICE_ID=price_...
# Segreto di firma del webhook (whsec_...), dato dal Dashboard o dalla CLI.
STRIPE_WEBHOOK_SECRET=whsec_...

# URL pubblico del sito, usato come fallback per i redirect di Checkout
# (success/cancel) quando l'header Origin non è disponibile.
PUBLIC_SITE_URL=https://il-tuo-dominio.vercel.app
